{
  "name": "fila-delivery",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "start:api": "npm run start -w apps/api",
    "backup:api": "npm run backup -w apps/api",
    "test:api": "npm run test -w apps/api",
    "test": "npm run test:api && npm run build:web",
    "build:web": "npm run build -w apps/web",
    "preview:web": "npm run preview -w apps/web"
  }
}
